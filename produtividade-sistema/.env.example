# Banco — OBRIGATÓRIO em produção (Railway)
# Vincule o plugin PostgreSQL e use a referência do Railway:
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Upload temporário durante importação (não armazena dados — vão para o PostgreSQL)
UPLOAD_DIR=/app/uploads

# Origens permitidas (ajuste para o domínio Railway)
CORS_ORIGINS=https://seu-app.up.railway.app

# Senha para liberar importação de planilhas no painel (ícone de engrenagem)
IMPORT_PASSWORD=altere_esta_senha_em_producao

# PORT é definido automaticamente pelo Railway
